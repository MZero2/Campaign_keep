generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CampaignStatus {
  ACTIVE
  ARCHIVED
}

enum SystemKey {
  DND_5E
}

enum CampaignRole {
  MASTER
  PLAYER
}

enum Visibility {
  PRIVATE_MASTER
  PUBLIC_CAMPAIGN
  OWNED_PRIVATE
}

enum QuestStatus {
  ACTIVE
  COMPLETED
  FAILED
  HIDDEN
}

model DndClassCatalog {
  id         String              @id @default(cuid())
  systemKey  String              @default("DND_2024")
  name       String
  hitDie     Int
  primaryAbility String?
  spellcastingAbility String?
  savingThrowProficiencies Json?
  subclassUnlockLevel Int      @default(3)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  subclasses DndSubclassCatalog[]
  features   DndClassFeatureCatalog[]
  selectedBy Character[]         @relation("CharacterClassCatalog")

  @@unique([systemKey, name])
  @@index([systemKey, name])
}

model DndSubclassCatalog {
  id         String          @id @default(cuid())
  classId    String
  name       String
  role       String?
  description String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  classRef   DndClassCatalog @relation(fields: [classId], references: [id], onDelete: Cascade)
  features   DndClassFeatureCatalog[]
  selectedBy Character[]     @relation("CharacterSubclassCatalog")

  @@unique([classId, name])
  @@index([name])
}

model DndFeatCatalog {
  id        String   @id @default(cuid())
  systemKey String   @default("DND_2024")
  name      String
  category  String
  source    String   @default("PHB 2024")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([systemKey, name])
  @@index([systemKey, category])
}

model DndActionCatalog {
  id          String   @id @default(cuid())
  systemKey   String   @default("DND_2024")
  name        String
  actionType  String
  description String
  source      String   @default("PHB 2024")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([systemKey, name])
  @@index([systemKey, actionType])
}

model DndSpellCatalog {
  id          String    @id @default(cuid())
  systemKey   String    @default("DND_2024")
  name        String
  level       Int
  school      String
  castingTime String
  range       String
  components  String
  duration    String
  description String
  damage      String?
  damageType  String?
  saveAbility String?
  attackType  String?
  scaling     String?
  classes     Json?
  source      String    @default("PHB 2024")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  knownBy     CharacterSpell[]

  @@unique([systemKey, name])
  @@index([systemKey, level])
}

model DndItemCatalog {
  id          String    @id @default(cuid())
  systemKey   String    @default("DND_2024")
  name        String
  category    String
  rarity      String?
  costCp      Int?
  weightLb    Float?
  description String
  damage      String?
  damageType  String?
  acBonus     Int?
  properties  Json?
  source      String    @default("PHB 2024")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  usedBy      CharacterInventoryItem[]

  @@unique([systemKey, name])
  @@index([systemKey, category])
}

model DndClassFeatureCatalog {
  id          String   @id @default(cuid())
  systemKey   String   @default("DND_2024")
  classId     String?
  subclassId  String?
  name        String
  level       Int
  actionType  String?
  description String
  source      String   @default("PHB 2024")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  classRef    DndClassCatalog?    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subclassRef DndSubclassCatalog? @relation(fields: [subclassId], references: [id], onDelete: Cascade)
  grantedTo   CharacterFeature[]

  @@index([systemKey, level])
  @@index([classId, level])
  @@index([subclassId, level])
}

model User {
  id                 String           @id @default(cuid())
  email              String           @unique
  passwordHash       String?
  authProvider       String           @default("credentials")
  displayName        String
  avatarUrl          String?
  masterPlanActive   Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  ownedCampaigns     Campaign[]       @relation("CampaignOwner")
  campaignMembership CampaignMember[]
  createdSessions    CampaignSession[]
  wikiPagesCreated   WikiPage[]       @relation("WikiPageCreator")
  wikiPagesUpdated   WikiPage[]       @relation("WikiPageUpdater")
  uploadedHandouts   Handout[]
  characters         Character[]
  playerNotes        PlayerNote[]
  invitesSent        CampaignInvite[] @relation("InviteSender")
}

model Campaign {
  id          String           @id @default(cuid())
  ownerId     String
  title       String
  slug        String           @unique
  description String
  coverUrl    String?
  systemKey   SystemKey        @default(DND_5E)
  status      CampaignStatus   @default(ACTIVE)
  visibility  Visibility       @default(PUBLIC_CAMPAIGN)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  owner       User             @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     CampaignMember[]
  invites     CampaignInvite[]
  sessions    CampaignSession[]
  wikiPages   WikiPage[]
  npcs        Npc[]
  locations   Location[]
  items       Item[]
  quests      Quest[]
  handouts    Handout[]
  characters  Character[]
  playerNotes PlayerNote[]
}

model CampaignMember {
  id         String       @id @default(cuid())
  campaignId String
  userId     String
  role       CampaignRole @default(PLAYER)
  joinedAt   DateTime     @default(now())
  campaign   Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([userId])
}

model CampaignInvite {
  id          String       @id @default(cuid())
  campaignId  String
  token       String       @unique
  email       String?
  role        CampaignRole @default(PLAYER)
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime     @default(now())
  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  invitedBy   User         @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model CampaignSession {
  id           String     @id @default(cuid())
  campaignId   String
  number       Int
  title        String
  playedAt     DateTime?
  publicRecap  String     @default("")
  privateNotes String     @default("")
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy    User       @relation(fields: [createdById], references: [id], onDelete: Restrict)
  npcs         Npc[]      @relation("SessionNpcs")
  locations    Location[] @relation("SessionLocations")
  quests       Quest[]    @relation("SessionQuests")
  handouts     Handout[]  @relation("SessionHandouts")

  @@unique([campaignId, number])
  @@index([campaignId, playedAt])
}

model WikiPage {
  id         String     @id @default(cuid())
  campaignId String
  title      String
  slug       String
  content    String
  visibility Visibility @default(PUBLIC_CAMPAIGN)
  tags       Json?
  createdBy  String
  updatedBy  String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator    User       @relation("WikiPageCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  updater    User       @relation("WikiPageUpdater", fields: [updatedBy], references: [id], onDelete: Restrict)

  @@unique([campaignId, slug])
  @@index([campaignId, updatedAt])
}

model Npc {
  id                String           @id @default(cuid())
  campaignId        String
  name              String
  publicDescription String           @default("")
  privateNotes      String           @default("")
  status            String           @default("unknown")
  faction           String?
  locationId        String?
  secrets           String           @default("")
  tags              Json?
  visibility        Visibility       @default(PUBLIC_CAMPAIGN)
  imageUrl          String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  campaign          Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location          Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  sessions          CampaignSession[] @relation("SessionNpcs")
  quests            Quest[]          @relation("QuestNpcs")
  handouts          Handout[]        @relation("NpcHandouts")

  @@index([campaignId, name])
}

model Location {
  id                String            @id @default(cuid())
  campaignId        String
  name              String
  publicDescription String            @default("")
  privateNotes      String            @default("")
  parentLocationId  String?
  discovered        Boolean           @default(false)
  visibility        Visibility        @default(PUBLIC_CAMPAIGN)
  imageUrl          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  campaign          Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  parentLocation    Location?         @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: SetNull)
  childLocations    Location[]        @relation("LocationHierarchy")
  npcs              Npc[]
  quests            Quest[]           @relation("QuestLocations")
  handouts          Handout[]         @relation("LocationHandouts")
  sessions          CampaignSession[] @relation("SessionLocations")

  @@index([campaignId, name])
}

model Item {
  id               String      @id @default(cuid())
  campaignId       String
  name             String
  type             String?
  rarity           String?
  description      String      @default("")
  effects          String      @default("")
  visibility       Visibility  @default(PUBLIC_CAMPAIGN)
  imageUrl         String?
  ownerCharacterId String?
  notes            String      @default("")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  campaign         Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ownerCharacter   Character?  @relation(fields: [ownerCharacterId], references: [id], onDelete: SetNull)
  inventoryItems   CharacterInventoryItem[]

  @@index([campaignId, name])
}

model Quest {
  id          String            @id @default(cuid())
  campaignId  String
  title       String
  summary     String            @default("")
  description String            @default("")
  status      QuestStatus       @default(ACTIVE)
  objectives  Json?
  rewards     Json?
  visibility  Visibility        @default(PUBLIC_CAMPAIGN)
  publicNotes String            @default("")
  privateNotes String           @default("")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  campaign    Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  npcs        Npc[]             @relation("QuestNpcs")
  locations   Location[]        @relation("QuestLocations")
  sessions    CampaignSession[] @relation("SessionQuests")
  handouts    Handout[]         @relation("QuestHandouts")

  @@index([campaignId, status])
}

model Handout {
  id          String            @id @default(cuid())
  campaignId  String
  title       String
  description String            @default("")
  fileUrl     String
  fileType    String
  visibility  Visibility        @default(PUBLIC_CAMPAIGN)
  tags        Json?
  uploadedById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  campaign    Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  uploadedBy  User              @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  sessions    CampaignSession[] @relation("SessionHandouts")
  npcs        Npc[]             @relation("NpcHandouts")
  locations   Location[]        @relation("LocationHandouts")
  quests      Quest[]           @relation("QuestHandouts")

  @@index([campaignId, createdAt])
}

model Character {
  id            String                   @id @default(cuid())
  campaignId    String
  ownerUserId   String
  classCatalogId String?
  subclassCatalogId String?
  name          String
  className     String?
  subclassName  String?
  level         Int                      @default(1)
  raceName      String?
  background    String?
  alignment     String?
  notes         String                   @default("")
  isActive      Boolean                  @default(true)
  visibility    Visibility               @default(PUBLIC_CAMPAIGN)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  campaign      Campaign                 @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ownerUser     User                     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  classCatalog  DndClassCatalog?         @relation("CharacterClassCatalog", fields: [classCatalogId], references: [id], onDelete: SetNull)
  subclassCatalog DndSubclassCatalog?    @relation("CharacterSubclassCatalog", fields: [subclassCatalogId], references: [id], onDelete: SetNull)
  stats         CharacterStats?
  inventory     CharacterInventoryItem[]
  spells        CharacterSpell[]
  attacks       CharacterAttack[]
  actions       CharacterAction[]
  features      CharacterFeature[]
  feats         CharacterFeat[]
  playerNotes   PlayerNote[]
  assignedItems Item[]

  @@index([campaignId, ownerUserId])
}

model CharacterFeature {
  id          String    @id @default(cuid())
  characterId String
  catalogFeatureId String?
  name        String
  level       Int?
  actionType  String?
  description String
  source      String    @default("Character Sheet")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  catalogFeature DndClassFeatureCatalog? @relation(fields: [catalogFeatureId], references: [id], onDelete: SetNull)

  @@index([characterId, level])
}

model CharacterAttack {
  id          String    @id @default(cuid())
  characterId String
  name        String
  ability     String?
  attackBonus Int?
  damageDice  String?
  damageType  String?
  notes       String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
}

model CharacterAction {
  id          String    @id @default(cuid())
  characterId String
  name        String
  actionType  String
  description String
  source      String    @default("Character Sheet")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, actionType])
}

model CharacterFeat {
  id          String    @id @default(cuid())
  characterId String
  name        String
  category    String
  source      String    @default("PHB 2024")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, category])
  @@unique([characterId, name])
}

model CharacterStats {
  id               String    @id @default(cuid())
  characterId      String    @unique
  str              Int       @default(10)
  dex              Int       @default(10)
  con              Int       @default(10)
  int              Int       @default(10)
  wis              Int       @default(10)
  cha              Int       @default(10)
  savingThrows     Json?
  skills           Json?
  hpCurrent        Int       @default(10)
  hpMax            Int       @default(10)
  ac               Int       @default(10)
  speed            Int       @default(30)
  initiativeBonus  Int       @default(0)
  proficiencyBonus Int       @default(2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model CharacterInventoryItem {
  id             String    @id @default(cuid())
  characterId    String
  campaignItemId String?
  catalogItemId  String?
  name           String
  quantity       Int       @default(1)
  description    String    @default("")
  equipped       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  campaignItem   Item?     @relation(fields: [campaignItemId], references: [id], onDelete: SetNull)
  catalogItem    DndItemCatalog? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
}

model CharacterSpell {
  id          String    @id @default(cuid())
  characterId String
  catalogSpellId String?
  name        String
  level       Int       @default(0)
  school      String?
  castingTime String?
  range       String?
  components  String?
  duration    String?
  description String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  catalogSpell DndSpellCatalog? @relation(fields: [catalogSpellId], references: [id], onDelete: SetNull)
}

model PlayerNote {
  id          String     @id @default(cuid())
  campaignId  String
  ownerUserId String
  characterId String?
  title       String
  content     String
  visibility  Visibility @default(OWNED_PRIVATE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  campaign    Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ownerUser   User       @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([campaignId, ownerUserId])
}
